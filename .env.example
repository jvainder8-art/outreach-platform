# Shared Google OAuth keys (same GCP project for all OAuth clients)
GMAIL_KEYS={"installed":{"client_id":"...","client_secret":"...",...}}

# Sabina
GMAIL_CREDENTIALS_SABINA={"access_token":"...","refresh_token":"...",...}
GEMINI_API_KEY=your-gemini-key

# DRVCares
GMAIL_CREDENTIALS_DRVCARES={"access_token":"...","refresh_token":"...",...}
DRVCARES_APP_PASSWORD=your-app-password
CLAUDE_API_KEY=sk-ant-api03-...

# DRVCares welcome packet — base64-encoded PDF
# Generate with: base64 -i "Welcome Packet.pdf" | tr -d '\n'
# Set as a GitHub Secret named DRVCARES_WELCOME_PACKET_B64
DRVCARES_WELCOME_PACKET_B64=your-base64-encoded-pdf
